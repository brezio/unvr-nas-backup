# Required — hostname or IP of the Unifi CloudKey / UNVR
PROTECT_HOST=

# SSH settings for CloudKey
PROTECT_SSH_USER=root
PROTECT_SSH_PORT=22

# Path to video files on the CloudKey
PROTECT_VIDEO_PATH=/srv/unifi-protect/video

# PostgreSQL on CloudKey
PROTECT_DB_PORT=5433
PROTECT_DB_NAME=unifi-protect

# How many hours back to look for recordings
BACKUP_HOURS=1

# SCP batching — copy N files, then pause BATCH_DELAY seconds
BATCH_SIZE=5
BATCH_DELAY=30

# Host path where archived .mp4 files are stored
ARCHIVE_PATH=

# Host path to SSH keys (must contain a key authorized on CloudKey)
SSH_KEY_PATH=~/.ssh

# Cron schedule (default: every hour)
CRON_SCHEDULE=0 * * * *

# Run a backup immediately on container start
RUN_ON_START=true

# Timezone
TZ=UTC

# Log level: debug, info, warn, error
LOG_LEVEL=info
